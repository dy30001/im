# Feishu app credentials
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# OpenClaw / Weixin bridge
# Text-only MVP that talks to the same HTTP API used by @tencent-weixin/openclaw-weixin.
# Leave CODEX_IM_OPENCLAW_TOKEN empty to trigger QR login on startup.
# Optional instance id for multi-account deployment, for example: wx1 / wx2.
CODEX_IM_OPENCLAW_INSTANCE_ID=
CODEX_IM_OPENCLAW_BASE_URL=https://ilinkai.weixin.qq.com
CODEX_IM_OPENCLAW_TOKEN=
# Minimal mode keeps only the core path: poll -> Codex -> reply.
# It disables desktop thread sync, turn stall watchdog, and OpenClaw progress notices.
# When CODEX_IM_OPENCLAW_THREAD_SOURCE is not set explicitly, minimal mode defaults to `codex`.
CODEX_IM_OPENCLAW_MINIMAL_MODE=false
CODEX_IM_OPENCLAW_THREAD_SOURCE=acpx
CODEX_IM_OPENCLAW_LONG_POLL_TIMEOUT_MS=35000
CODEX_IM_OPENCLAW_STREAMING_OUTPUT=true
CODEX_IM_OPENCLAW_REPLY_FLUSH_DELAY_MS=50
CODEX_IM_OPENCLAW_PROGRESS_NOTICE_DELAY_MS=200
CODEX_IM_OPENCLAW_TURN_STALL_TIMEOUT_MS=1800000
CODEX_IM_OPENCLAW_TURN_STALL_CHECK_INTERVAL_MS=30000
CODEX_IM_OPENCLAW_HEARTBEAT_TIMEOUT_MS=600000
CODEX_IM_OPENCLAW_STARTUP_HEARTBEAT_TIMEOUT_MS=180000
CODEX_IM_OPENCLAW_HEARTBEAT_CHECK_INTERVAL_MS=60000
# Leave these empty to use instance-aware defaults:
# - credentials  -> ~/.codex-im/openclaw-credentials.<instance>.json
# - sessions     -> ~/.codex-im/openclaw-sessions.<instance>.json
# - heartbeat    -> ~/.codex-im/openclaw-bot.<instance>.lock/heartbeat.json
# - log          -> /tmp/codex-im-openclaw-<instance>.log
CODEX_IM_OPENCLAW_CREDENTIALS_FILE=/Users/your-name/.codex-im/openclaw-credentials.json
CODEX_IM_OPENCLAW_ACPX_SESSIONS_DIR=/Users/your-name/.acpx/sessions
CODEX_IM_OPENCLAW_ACPX_SESSION_INDEX_FILE=/Users/your-name/.acpx/sessions/index.json

# Voice messages are handled as plain text via `voice_item.text`.
# No separate speech-to-text dependencies or config are required.

# Codex model
CODEX_IM_DEFAULT_CODEX_MODEL=gpt-5.4
CODEX_IM_DEFAULT_CODEX_EFFORT=xhigh
CODEX_IM_DEFAULT_CODEX_ACCESS_MODE=full-access

# Bot behavior
CODEX_IM_DEFAULT_WORKSPACE_ID=default
# Optional default project path. When set, new unbound chats auto-bind to this workspace.
CODEX_IM_DEFAULT_WORKSPACE_ROOT=
# Whether Feishu replies are streamed in real time.
# true  = stream card updates (default)
# false = send once after run completes
CODEX_IM_FEISHU_STREAMING_OUTPUT=true

# Verbose Codex transport logs and event traces.
# false = quieter output (recommended)
CODEX_IM_VERBOSE_LOGS=false

# Restrict which local directories can be bound from Feishu
# Comma-separated absolute paths. Leave empty to allow only directories under your home folder.
CODEX_IM_WORKSPACE_ALLOWLIST=

# Optional explicit Codex endpoint. Leave empty to spawn `codex app-server`.
CODEX_IM_CODEX_ENDPOINT=

# Optional session persistence location
# Leave empty to use per-channel defaults:
# - feishu-bot   -> ~/.codex-im/feishu-sessions.json
# - openclaw-bot -> ~/.codex-im/openclaw-sessions.json
# The legacy ~/.codex-im/sessions.json file is still used as a read-only fallback on first run.
CODEX_IM_SESSIONS_FILE=
