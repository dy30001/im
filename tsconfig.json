{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "bin/**/*.js",
    "src/**/*.js",
    "test/**/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
